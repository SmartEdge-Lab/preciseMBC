---
import { Icon } from 'astro-icon/components';
import '../styles/global.css';

const defaultLocalePath = '/en/';
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`1;url=${defaultLocalePath}`} />
    <title>Precise MBC | Loading</title>
    <script is:inline define:vars={{ defaultLocalePath }}>
      window.setTimeout(() => {
        window.location.replace(defaultLocalePath);
      }, 700);
    </script>
  </head>
  <body class="min-h-full bg-gradient-hero text-burgundy-500 antialiased">
    <main class="min-h-screen flex items-center justify-center px-6 py-12">
      <section
        class="w-full max-w-sm text-center"
        aria-labelledby="redirect-title"
        aria-describedby="redirect-description"
      >
        <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-burgundy-500 shadow-card">
          <Icon name="lucide:file-check-2" class="h-7 w-7 text-white" aria-hidden="true" />
        </div>

        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.12em] text-dusty-rose-600">
          Precise MBC
        </p>
        <h1 id="redirect-title" class="font-display text-2xl font-bold text-burgundy-500">
          Loading your experience
        </h1>
        <p id="redirect-description" class="mt-3 text-sm leading-6 text-gray-600">
          We are taking you to the English version of the site.
        </p>

        <div class="mx-auto mt-8 flex w-32 items-center justify-center gap-2" aria-hidden="true">
          <span class="loading-dot"></span>
          <span class="loading-dot animation-delay-150"></span>
          <span class="loading-dot animation-delay-300"></span>
        </div>

        <p class="mt-8 text-xs text-gray-500">
          If nothing happens, <a class="font-semibold text-dusty-rose-600 underline-offset-4 hover:underline" href={defaultLocalePath}>continue to Precise MBC</a>.
        </p>
      </section>
    </main>
    <form name="quick-lead" method="POST" action="/" data-netlify="true" netlify-honeypot="bot-field" hidden>
      <input type="hidden" name="form-name" value="quick-lead" />
      <input type="hidden" name="source" value="homepage_cta" />
      <input type="hidden" name="language" value="en" />
      <input name="clinic" type="text" />
      <input name="email" type="email" />
      <input name="bot-field" />
    </form>
    <form name="practice-inquiry" method="POST" action="/" data-netlify="true" netlify-honeypot="bot-field" hidden>
      <input type="hidden" name="form-name" value="practice-inquiry" />
      <input type="hidden" name="source" value="contact_section" />
      <input type="hidden" name="language" value="en" />
      <input name="name" type="text" />
      <input name="email" type="email" />
      <input name="phone" type="tel" />
      <input name="clinic" type="text" />
      <input name="ehr" type="text" />
      <textarea name="message"></textarea>
      <input name="bot-field" />
    </form>
  </body>
</html>

<style>
  .loading-dot {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 9999px;
    background: #0369a1;
    animation: loading-pulse 1s ease-in-out infinite;
  }

  .animation-delay-150 {
    animation-delay: 150ms;
  }

  .animation-delay-300 {
    animation-delay: 300ms;
  }

  @keyframes loading-pulse {
    0%,
    100% {
      opacity: 0.3;
      transform: translateY(0);
    }

    50% {
      opacity: 1;
      transform: translateY(-0.35rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .loading-dot {
      animation: none;
    }
  }
</style>
