---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import ThemeLogo from '../ui/ThemeLogo.astro';
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = `/${lang}`;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="header-inner transition-all duration-300">
    <Container>
      <div class="flex items-center justify-between h-16 md:h-20">

        <!-- Logo -->
        <a href={base} class="flex items-center gap-3 group" aria-label="Precise MBC – Home">
          <ThemeLogo
            alt="Precise MBC logo"
            width="40"
            height="40"
            class="h-10 w-10 object-contain"
            loading="eager"
            decoding="async"
          />
          <div class="leading-tight">
            <div class="font-display font-bold text-burgundy-500 text-lg">Precise MBC</div>
            <div class="text-xs text-gray-500 hidden sm:block">Medical Billing & Coding</div>
          </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
          <a href={`${base}#services`} class="text-sm font-medium text-gray-700 hover:text-burgundy-500 transition-colors">{t('nav.services')}</a>
          <a href={`${base}#obgyn`} class="text-sm font-medium text-gray-700 hover:text-burgundy-500 transition-colors">{t('nav.specialty')}</a>
          <a href={`${base}#process`} class="text-sm font-medium text-gray-700 hover:text-burgundy-500 transition-colors">{t('nav.process')}</a>
          <a href={`${base}#faq`} class="text-sm font-medium text-gray-700 hover:text-burgundy-500 transition-colors">{t('nav.faq')}</a>
          <a href={`${base}#contact`} class="text-sm font-medium text-gray-700 hover:text-burgundy-500 transition-colors">{t('nav.contact')}</a>
        </nav>

        <!-- Actions -->
        <div class="flex items-center gap-3">
          <ThemeToggle lang={lang} />
          <LanguageSwitcher lang={lang} />
          <Button href={`${base}#contact`} size="sm" class="hidden sm:inline-flex">
            {t('nav.cta')}
          </Button>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            type="button"
            class="lg:hidden p-2 rounded-lg text-gray-600 hover:text-burgundy-500 hover:bg-burgundy-50 transition-colors"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <Icon name="lucide:menu" class="w-5 h-5 menu-icon" aria-hidden="true" />
            <Icon name="lucide:x" class="w-5 h-5 close-icon hidden" aria-hidden="true" />
          </button>
        </div>
      </div>
    </Container>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-burgundy-100 bg-white/95 backdrop-blur-md shadow-lg"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <Container>
      <nav class="py-4 flex flex-col gap-1">
        <a href={`${base}#services`} class="mobile-nav-link px-4 py-3 rounded-lg text-sm font-medium text-gray-700 hover:bg-burgundy-50 hover:text-burgundy-500 transition-colors">{t('nav.services')}</a>
        <a href={`${base}#obgyn`} class="mobile-nav-link px-4 py-3 rounded-lg text-sm font-medium text-gray-700 hover:bg-burgundy-50 hover:text-burgundy-500 transition-colors">{t('nav.specialty')}</a>
        <a href={`${base}#process`} class="mobile-nav-link px-4 py-3 rounded-lg text-sm font-medium text-gray-700 hover:bg-burgundy-50 hover:text-burgundy-500 transition-colors">{t('nav.process')}</a>
        <a href={`${base}#faq`} class="mobile-nav-link px-4 py-3 rounded-lg text-sm font-medium text-gray-700 hover:bg-burgundy-50 hover:text-burgundy-500 transition-colors">{t('nav.faq')}</a>
        <a href={`${base}#contact`} class="mobile-nav-link px-4 py-3 rounded-lg text-sm font-medium text-gray-700 hover:bg-burgundy-50 hover:text-burgundy-500 transition-colors">{t('nav.contact')}</a>
        <div class="pt-2 border-t border-gray-100 mt-2">
          <Button href={`${base}#contact`} class="w-full justify-center">
            {t('nav.cta')}
          </Button>
        </div>
      </nav>
    </Container>
  </div>
</header>

<style>
  .header-inner {
    background: transparent;
  }

  #site-header.scrolled .header-inner {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(29, 78, 216, 0.1);
    box-shadow: 0 2px 20px -4px rgba(29, 78, 216, 0.1);
  }

  :global(html[data-theme='dark']) #site-header.scrolled .header-inner {
    background: rgba(2, 6, 23, 0.82);
    border-bottom: 1px solid rgba(148, 163, 184, 0.16);
    box-shadow: 0 8px 30px -20px rgba(2, 6, 23, 0.9);
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = btn?.querySelector('.menu-icon');
  const closeIcon = btn?.querySelector('.close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    menuIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  });

  // Close mobile menu on nav link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
