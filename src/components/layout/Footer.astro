---
import Container from '../ui/Container.astro';
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = `/${lang}`;
---

<footer class="bg-gray-950 text-gray-300">
  <Container>
    <div class="py-12 lg:py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href={base} class="mb-4 flex items-center gap-3">
          <img
            src="/logo_white.png"
            alt="Precise MBC logo"
            width="40"
            height="40"
            class="h-10 w-10 object-contain"
            loading="lazy"
            decoding="async"
          />
          <div>
            <span class="font-display text-lg font-bold text-white">Precise MBC</span>
            <div class="text-xs text-gray-500">Medical Billing & Coding</div>
          </div>
        </a>
        <p class="mb-6 text-sm leading-relaxed text-gray-400">{t('footer.tagline')}</p>

        <!-- Contact info -->
        <div class="space-y-2 text-sm">
          <a href={`tel:${t('contact.info.phone').replace(/\D/g, '')}`} class="flex items-center gap-2 text-gray-400 hover:text-champagne-400 transition-colors">
            <Icon name="lucide:phone" class="w-4 h-4 flex-shrink-0" aria-hidden="true" />
            {t('contact.info.phone')}
          </a>
          <a href={`mailto:${t('contact.info.email')}`} class="flex items-center gap-2 text-gray-400 hover:text-champagne-400 transition-colors">
            <Icon name="lucide:mail" class="w-4 h-4 flex-shrink-0" aria-hidden="true" />
            {t('contact.info.email')}
          </a>
          <div class="flex items-center gap-2 text-gray-400">
            <Icon name="lucide:printer" class="w-4 h-4 flex-shrink-0" aria-hidden="true" />
            {t('contact.info.fax')}
          </div>
          <div class="flex items-center gap-2 text-gray-400">
            <Icon name="lucide:map-pin" class="w-4 h-4 flex-shrink-0" aria-hidden="true" />
            {t('contact.info.address')}
          </div>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{t('footer.services.title')}</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href={`${base}#services`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('services.1.title')}</a></li>
          <li><a href={`${base}#services`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('services.2.title')}</a></li>
          <li><a href={`${base}#services`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('services.3.title')}</a></li>
          <li><a href={`${base}#services`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('services.4.title')}</a></li>
          <li><a href={`${base}#services`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('services.5.title')}</a></li>
          <li><a href={`${base}#services`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('services.6.title')}</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{t('footer.resources.title')}</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href={`${base}#obgyn`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('nav.specialty')}</a></li>
          <li><a href={`${base}#process`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('nav.process')}</a></li>
          <li><a href={`${base}#faq`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('nav.faq')}</a></li>
          <li><a href={`${base}#contact`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('nav.contact')}</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{t('footer.legal.title')}</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href={`${base}/privacy`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('footer.privacy')}</a></li>
          <li><a href={`${base}/terms`} class="text-gray-400 hover:text-champagne-400 transition-colors">{t('footer.terms')}</a></li>
        </ul>

        <!-- Trust badges -->
        <div class="mt-6">
          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-2 py-1 rounded bg-gray-800 text-gray-400 border border-gray-700">Privacy</span>
            <span class="text-xs px-2 py-1 rounded bg-gray-800 text-gray-400 border border-gray-700">Coding</span>
            <span class="text-xs px-2 py-1 rounded bg-gray-800 text-gray-400 border border-gray-700">OBGYN</span>
            <span class="text-xs px-2 py-1 rounded bg-gray-800 text-gray-400 border border-gray-700">Claims</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500">
      <p>{t('footer.copyright')}</p>
      <p class="text-center sm:text-right max-w-md">{t('footer.disclaimer')}</p>
    </div>
  </Container>
</footer>
