---
import Container from '../ui/Container.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="bg-burgundy-500 py-14 sm:py-16">
  <Container>
    <div class="grid items-center gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(360px,0.8fr)]">
      <div>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
          {t('cta.title')}
        </h2>
        <p class="max-w-2xl text-base sm:text-lg text-burgundy-200">
          {t('cta.subtitle')}
        </p>
      </div>

      <div class="rounded-lg border border-white/15 bg-white/10 p-4 sm:p-5 shadow-card backdrop-blur-sm">
        <form
          id="cta-form"
          name="quick-lead"
          method="POST"
          action="/"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-3"
          novalidate
          aria-label={t('cta.form.label')}
        >
          <input type="hidden" name="form-name" value="quick-lead" />
          <input type="hidden" name="source" value="homepage_cta" />
          <input type="hidden" name="language" value={lang} />
          <p class="hidden">
            <label>
              Do not fill this out if you are human:
              <input name="bot-field" tabindex="-1" autocomplete="off" />
            </label>
          </p>

          <div>
            <label for={`cta-clinic-${lang}`} class="sr-only">{t('contact.form.clinic')}</label>
            <input
              id={`cta-clinic-${lang}`}
              name="clinic"
              type="text"
              required
              autocomplete="organization"
              placeholder={t('cta.clinic.placeholder')}
              aria-describedby={`cta-clinic-error-${lang}`}
              class="w-full px-4 py-3 rounded-lg bg-white text-burgundy-500 placeholder-slate-400 border border-white/20 focus:outline-none focus:border-dusty-rose-500 focus:ring-2 focus:ring-sky-200 transition-all duration-200 text-sm"
            />
            <p id={`cta-clinic-error-${lang}`} data-error-for="clinic" class="cta-field-error hidden mt-1.5 text-xs font-medium text-champagne-300">
              {t('cta.validation.clinic')}
            </p>
          </div>

          <div class="grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto]">
            <div>
              <label for={`cta-email-${lang}`} class="sr-only">{t('contact.form.email')}</label>
              <input
                id={`cta-email-${lang}`}
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder={t('cta.input.placeholder')}
                aria-describedby={`cta-email-error-${lang}`}
                class="w-full px-4 py-3 rounded-lg bg-white text-burgundy-500 placeholder-slate-400 border border-white/20 focus:outline-none focus:border-dusty-rose-500 focus:ring-2 focus:ring-sky-200 transition-all duration-200 text-sm"
              />
              <p id={`cta-email-error-${lang}`} data-error-for="email" class="cta-field-error hidden mt-1.5 text-xs font-medium text-champagne-300">
                {t('cta.validation.email')}
              </p>
            </div>
            <button
              id="cta-submit"
              type="submit"
              data-sending-label={t('cta.sending')}
              class="inline-flex min-h-12 items-center justify-center rounded-lg bg-champagne-400 px-5 py-3 text-sm font-semibold text-burgundy-600 shadow-lg transition-colors duration-200 hover:bg-champagne-300 disabled:cursor-not-allowed disabled:opacity-70"
            >
              {t('cta.cta')}
            </button>
          </div>
        </form>

        <p id="cta-success" class="hidden mt-4 text-sm font-medium text-champagne-300" role="status" aria-live="polite">
          {t('cta.sent')}
        </p>
        <p id="cta-error" class="hidden mt-4 rounded-lg bg-white/10 p-3 text-sm font-medium text-white" role="alert" aria-live="assertive">
          {t('cta.error')}
        </p>
      </div>
    </div>
  </Container>
</section>

<script>
  const form = document.getElementById('cta-form') as HTMLFormElement | null;
  const success = document.getElementById('cta-success');
  const error = document.getElementById('cta-error');
  const submit = document.getElementById('cta-submit') as HTMLButtonElement | null;
  const clinicInput = form?.querySelector<HTMLInputElement>('input[name="clinic"]');
  const emailInput = form?.querySelector<HTMLInputElement>('input[name="email"]');
  const clinicError = form?.querySelector<HTMLElement>('[data-error-for="clinic"]');
  const emailError = form?.querySelector<HTMLElement>('[data-error-for="email"]');

  const setInvalid = (
    input: HTMLInputElement | undefined | null,
    message: HTMLElement | undefined | null,
    invalid: boolean,
  ) => {
    input?.setAttribute('aria-invalid', String(invalid));
    input?.classList.toggle('border-dusty-rose-500', invalid);
    input?.classList.toggle('ring-2', invalid);
    input?.classList.toggle('ring-champagne-300', invalid);
    message?.classList.toggle('hidden', !invalid);
  };

  const validateQuickLead = () => {
    const clinicInvalid = !clinicInput?.value.trim();
    const emailInvalid = !emailInput?.validity.valid;

    setInvalid(clinicInput, clinicError, clinicInvalid);
    setInvalid(emailInput, emailError, emailInvalid);

    return !clinicInvalid && !emailInvalid;
  };

  [clinicInput, emailInput].forEach((input) => {
    input?.addEventListener('input', () => {
      if (input.getAttribute('aria-invalid') === 'true') {
        validateQuickLead();
      }
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submit) return;
    if (!validateQuickLead()) return;

    const defaultLabel = submit.textContent ?? '';
    submit.disabled = true;
    submit.textContent = submit.dataset.sendingLabel ?? defaultLabel;
    success?.classList.add('hidden');
    error?.classList.add('hidden');

    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(
          Array.from(new FormData(form), ([key, value]) => [key, String(value)]),
        ),
      });
      if (res.ok) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
      } else {
        error?.classList.remove('hidden');
      }
    } catch {
      error?.classList.remove('hidden');
    } finally {
      submit.disabled = false;
      submit.textContent = defaultLabel;
    }
  });
</script>
