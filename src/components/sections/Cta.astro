---
import Container from '../ui/Container.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
---

<section class="bg-burgundy-500 py-16 sm:py-20">
  <Container>
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
        {t('cta.title')}
      </h2>
      <p class="text-lg text-burgundy-200 mb-10">
        {t('cta.subtitle')}
      </p>

      <form
        id="cta-form"
        class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto"
        novalidate
        aria-label="Quick contact form"
      >
        <div class="flex-1">
          <label for="cta-email" class="sr-only">{t('contact.form.email')}</label>
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input
            id="cta-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder={t('cta.input.placeholder')}
            class="w-full px-4 py-3 rounded-lg bg-white/10 text-white placeholder-burgundy-300 border border-white/30 focus:outline-none focus:border-white focus:bg-white/15 transition-all duration-200 text-sm"
          />
        </div>
        <button
          type="submit"
          class="px-6 py-3 rounded-lg bg-white text-burgundy-600 font-semibold text-sm hover:bg-ivory-50 transition-colors duration-200 shadow-lg whitespace-nowrap"
        >
          {t('cta.cta')}
        </button>
      </form>

      <p id="cta-success" class="hidden mt-4 text-champagne-300 font-medium text-sm" role="status" aria-live="polite">
        {t('cta.sent')}
      </p>
    </div>
  </Container>
</section>

<script>
  const form = document.getElementById('cta-form') as HTMLFormElement | null;
  const success = document.getElementById('cta-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new URLSearchParams({
          access_key: data.get('access_key') as string,
          email: data.get('email') as string,
          subject: 'New Lead - Precise MBC Website Inquiry',
        }),
      });
      if (res.ok) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
      }
    } catch {
      // silently fail — main contact form is the primary channel
    }
  });
</script>
