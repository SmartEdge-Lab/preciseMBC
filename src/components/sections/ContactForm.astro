---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Section id="contact" bg="white">
  <Container>
    <div class="text-center max-w-2xl mx-auto mb-12">
      <Badge variant="rose" class="mb-4">{t('contact.eyebrow')}</Badge>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-burgundy-500 mb-4">
        {t('contact.title')}
      </h2>
      <p class="text-lg text-gray-600">{t('contact.subtitle')}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-start">

      <!-- Contact Form -->
      <div class="bg-white rounded-lg border border-slate-200 shadow-card p-6 sm:p-8">
        <form
          id="contact-form"
          name="practice-inquiry"
          method="POST"
          action="/"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-5"
          aria-label={t('contact.title')}
        >
          <input type="hidden" name="form-name" value="practice-inquiry" />
          <input type="hidden" name="source" value="contact_section" />
          <input type="hidden" name="language" value={lang} />
          <!-- Honeypot -->
          <p class="hidden">
            <label>
              Do not fill this out if you are human:
              <input name="bot-field" tabindex="-1" autocomplete="off" />
            </label>
          </p>

          <div class="grid sm:grid-cols-2 gap-5">
            <!-- Name -->
            <div>
              <label for="cf-name" class="block text-sm font-medium text-gray-700 mb-1.5">
                {t('contact.form.name')} <span class="text-dusty-rose-500" aria-hidden="true">*</span>
              </label>
              <input
                id="cf-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-dusty-rose-500 focus:ring-2 focus:ring-sky-100 transition-all duration-200"
                placeholder="Dr. Jane Smith"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="cf-phone" class="block text-sm font-medium text-gray-700 mb-1.5">
                {t('contact.form.phone')}
              </label>
              <input
                id="cf-phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-dusty-rose-500 focus:ring-2 focus:ring-sky-100 transition-all duration-200"
                placeholder="+1 (786) 535-7256"
              />
            </div>
          </div>

          <!-- Email -->
          <div>
            <label for="cf-email" class="block text-sm font-medium text-gray-700 mb-1.5">
              {t('contact.form.email')} <span class="text-dusty-rose-500" aria-hidden="true">*</span>
            </label>
            <input
              id="cf-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-dusty-rose-500 focus:ring-2 focus:ring-sky-100 transition-all duration-200"
              placeholder="doctor@clinic.com"
            />
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <!-- Clinic -->
            <div>
              <label for="cf-clinic" class="block text-sm font-medium text-gray-700 mb-1.5">
                {t('contact.form.clinic')}
              </label>
              <input
                id="cf-clinic"
                name="clinic"
                type="text"
                class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-dusty-rose-500 focus:ring-2 focus:ring-sky-100 transition-all duration-200"
                placeholder="Miami Women's Health"
              />
            </div>

            <!-- EHR -->
            <div>
              <label for="cf-ehr" class="block text-sm font-medium text-gray-700 mb-1.5">
                {t('contact.form.ehr')}
              </label>
              <select
                id="cf-ehr"
                name="ehr"
                class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:border-dusty-rose-500 focus:ring-2 focus:ring-sky-100 transition-all duration-200 appearance-none"
              >
                <option value="">{t('contact.form.ehrPlaceholder')}</option>
                <option>Athena Health</option>
                <option>eClinicalWorks</option>
                <option>Kareo</option>
                <option>Practice Fusion</option>
                <option>DrChrono</option>
                <option>Modernizing Medicine</option>
                <option>Other</option>
              </select>
            </div>
          </div>

          <!-- Message -->
          <div>
            <label for="cf-message" class="block text-sm font-medium text-gray-700 mb-1.5">
              {t('contact.form.message')}
            </label>
            <textarea
              id="cf-message"
              name="message"
              rows="4"
              class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-dusty-rose-500 focus:ring-2 focus:ring-sky-100 transition-all duration-200 resize-none"
              placeholder="Tell us about your practice and current billing challenges..."
            ></textarea>
          </div>

          <!-- Status messages -->
          <p id="cf-success" class="hidden text-sm text-green-600 font-medium p-3 bg-green-50 rounded-lg" role="status" aria-live="polite">
            {t('contact.form.success')}
          </p>
          <p id="cf-error" class="hidden text-sm text-dusty-rose-600 font-medium p-3 bg-red-50 rounded-lg" role="alert" aria-live="assertive">
            {t('contact.form.error')}
          </p>

          <Button
            type="submit"
            class="w-full justify-center"
            size="lg"
            id="cf-submit"
            data-sending-label={t('contact.form.sending')}
          >
            <Icon name="lucide:send" class="w-5 h-5" aria-hidden="true" />
            {t('contact.form.submit')}
          </Button>
        </form>
      </div>

      <!-- Right: Calendly + contact info -->
      <div class="space-y-6">
        <!-- Contact quick info -->
        <div class="bg-ivory-50 rounded-lg p-6 border border-burgundy-100">
          <h3 class="text-base font-semibold text-gray-900 mb-4">{t('contact.quickinfo.title')}</h3>
          <div class="space-y-3 text-sm">
            <a href={`tel:${t('contact.info.phone').replace(/\D/g, '')}`} class="flex items-center gap-3 text-gray-600 hover:text-burgundy-600 transition-colors">
              <div class="w-8 h-8 bg-burgundy-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <Icon name="lucide:phone" class="w-4 h-4 text-burgundy-600" aria-hidden="true" />
              </div>
              {t('contact.info.phone')}
            </a>
            <a href={`mailto:${t('contact.info.email')}`} class="flex items-center gap-3 text-gray-600 hover:text-burgundy-600 transition-colors">
              <div class="w-8 h-8 bg-burgundy-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <Icon name="lucide:mail" class="w-4 h-4 text-burgundy-600" aria-hidden="true" />
              </div>
              {t('contact.info.email')}
            </a>
            <div class="flex items-center gap-3 text-gray-600">
              <div class="w-8 h-8 bg-burgundy-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <Icon name="lucide:printer" class="w-4 h-4 text-burgundy-600" aria-hidden="true" />
              </div>
              {t('contact.info.fax')}
            </div>
            <div class="flex items-center gap-3 text-gray-600">
              <div class="w-8 h-8 bg-burgundy-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <Icon name="lucide:map-pin" class="w-4 h-4 text-burgundy-600" aria-hidden="true" />
              </div>
              {t('contact.info.address')}
            </div>
          </div>
        </div>

        <!-- Calendly placeholder -->
        <div class="bg-white rounded-lg border border-slate-200 shadow-card overflow-hidden">
          <div class="p-6 border-b border-gray-50">
            <h3 class="text-base font-semibold text-gray-900">{t('contact.calendly.title')}</h3>
          </div>
          <div class="p-6">
            <!-- Calendly inline widget placeholder -->
            <div
              class="calendly-inline-widget min-h-80 flex items-center justify-center bg-ivory-50 rounded-lg border-2 border-dashed border-burgundy-200"
              data-url="https://calendly.com/precisembc/consultation"
              style="min-width:280px"
            >
              <div class="text-center p-6">
                <div class="w-12 h-12 bg-burgundy-100 rounded-lg flex items-center justify-center mx-auto mb-3">
                  <Icon name="lucide:calendar-check" class="w-6 h-6 text-burgundy-600" aria-hidden="true" />
                </div>
                <p class="text-sm text-gray-500 mb-4">{t('contact.calendly.blurb')}</p>
                <a
                  href="https://calendly.com/precisembc/consultation"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-5 py-2.5 bg-burgundy-500 text-white text-sm font-semibold rounded-lg hover:bg-burgundy-600 transition-colors"
                >
                  {t('contact.calendly.cta')}
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('cf-success');
  const errorMsg = document.getElementById('cf-error');
  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn) return;

    submitBtn.disabled = true;
    const defaultLabel = submitBtn.textContent ?? '';
    submitBtn.textContent = submitBtn.dataset.sendingLabel ?? defaultLabel;
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(
          Array.from(new FormData(form), ([key, value]) => [key, String(value)]),
        ),
      });

      if (res.ok) {
        form.reset();
        successMsg?.classList.remove('hidden');
      } else {
        errorMsg?.classList.remove('hidden');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = defaultLabel;
    }
  });
</script>
