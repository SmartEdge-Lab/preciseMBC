---
import Container from '../ui/Container.astro';
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const badges = [
  { key: 'trust.hipaa', icon: 'lucide:shield-check', color: 'green' },
  { key: 'trust.aapc', icon: 'lucide:award', color: 'burgundy' },
  { key: 'trust.ahima', icon: 'lucide:bookmark-check', color: 'plum' },
  { key: 'trust.icd10', icon: 'lucide:code-xml', color: 'rose' },
  { key: 'trust.obgyn', icon: 'lucide:heart-pulse', color: 'champagne' },
] as const;
---

<div class="border-y border-burgundy-100 bg-white py-8">
  <Container>
    <p class="text-center text-xs font-semibold tracking-widest uppercase text-gray-400 mb-6">
      {t('trust.title')}
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8">
      {badges.map(({ key, icon, color }) => (
        <div class="flex items-center gap-2 text-sm font-medium text-gray-600">
          <div class={`w-7 h-7 rounded-lg flex items-center justify-center ${
            color === 'green' ? 'bg-green-100 text-green-600' :
            color === 'burgundy' ? 'bg-burgundy-100 text-burgundy-600' :
            color === 'plum' ? 'bg-plum-100 text-plum-700' :
            color === 'rose' ? 'bg-red-100 text-dusty-rose-500' :
            'bg-champagne-300/40 text-amber-700'
          }`}>
            <Icon name={icon} class="w-4 h-4" aria-hidden="true" />
          </div>
          <span>{t(key as any)}</span>
        </div>
      ))}
    </div>
  </Container>
</div>
