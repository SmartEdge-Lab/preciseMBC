---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Badge from '../ui/Badge.astro';
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const codes = ['1','2','3','4','5','6','7','8'] as const;
const risks = [
  { num: '1', icon: 'lucide:package-check' },
  { num: '2', icon: 'lucide:badge-percent' },
  { num: '3', icon: 'lucide:file-x-2' },
  { num: '4', icon: 'lucide:landmark' },
  { num: '5', icon: 'lucide:scan-line' },
  { num: '6', icon: 'lucide:clock-alert' },
] as const;
---

<Section id="obgyn" bg="white">
  <Container>
    <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-10 lg:gap-14 items-start">

      <!-- Left: Content -->
      <div class="lg:sticky lg:top-28">
        <Badge variant="plum" class="mb-4">{t('obgyn.eyebrow')}</Badge>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-burgundy-500 mb-6">
          {t('obgyn.title')}
        </h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          {t('obgyn.subtitle')}
        </p>

        <div class="rounded-lg border border-slate-200 bg-ivory-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-dusty-rose-500 mb-3">
            {t('obgyn.proof.eyebrow')}
          </p>
          <div class="flex flex-wrap gap-2">
            {codes.map(code => (
              <span class="rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-medium text-slate-600">
                {t(`obgyn.codes.${code}` as any)}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: revenue risk cards -->
      <div class="grid sm:grid-cols-2 gap-4">
        {risks.map(({ num, icon }) => (
          <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-card transition-colors duration-200 hover:border-dusty-rose-500">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-sky-100 bg-sky-50 text-dusty-rose-500">
              <Icon name={icon} class="h-5 w-5" aria-hidden="true" />
            </div>
            <h3 class="mb-2 text-base font-semibold text-slate-900">
              {t(`obgyn.risk.${num}.title` as any)}
            </h3>
            <p class="text-sm leading-relaxed text-slate-600">
              {t(`obgyn.risk.${num}.desc` as any)}
            </p>
          </article>
        ))}

        <div class="rounded-lg border border-plum-100 bg-plum-50 p-5 sm:col-span-2">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h3 class="text-base font-semibold text-plum-700">{t('obgyn.outcome.title')}</h3>
              <p class="mt-1 text-sm leading-relaxed text-slate-600">{t('obgyn.outcome.desc')}</p>
            </div>
            <a
              href={`/${lang}#contact`}
              class="inline-flex shrink-0 items-center justify-center rounded-lg bg-burgundy-500 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-burgundy-600"
            >
              {t('obgyn.outcome.cta')}
              <Icon name="lucide:arrow-right" class="ml-2 h-4 w-4" aria-hidden="true" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>
