---
import { SEO } from 'astro-seo';
import { getAlternateLang, getLocalizedPath } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  lang,
  canonical = Astro.url.href,
  ogImage = '/og-image.jpg',
} = Astro.props;

const alternateLang = getAlternateLang(lang);
const alternateUrl = new URL(
  `${getLocalizedPath(Astro.url.pathname, alternateLang)}${Astro.url.search}`,
  Astro.site ?? Astro.url,
).href;
const themeStorageKey = 'precise-theme-preference';
const faviconLight = '/favicon.png';
const faviconDark = '/favicon-white.png';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: 'Precise MBC',
  alternateName: 'Precise Medical Billing and Coding',
  description: 'Specialized OBGYN medical billing and coding services in Miami, FL.',
  url: 'https://precisembc.com',
  telephone: '+17865357256',
  faxNumber: '+17547324242',
  email: 'Admin@precisembc.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Miami',
    addressRegion: 'FL',
    postalCode: '33013',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 25.7617,
    longitude: -80.1918,
  },
  areaServed: {
    '@type': 'State',
    name: 'Florida',
  },
  medicalSpecialty: 'Obstetrics',
  priceRange: '$$',
  openingHours: 'Mo-Fr 08:00-18:00',
  sameAs: [
    'https://www.linkedin.com/company/precise-mbc',
  ],
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="32x32" href={faviconLight} media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="32x32" href={faviconDark} media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="192x192" href={faviconLight} />
    <link rel="apple-touch-icon" href={faviconLight} />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: {
          title,
          type: 'website',
          image: ogImage,
          url: canonical,
        },
        optional: {
          description,
          locale: lang === 'en' ? 'en_US' : 'es_MX',
          siteName: 'Precise MBC',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image: ogImage,
      }}
      extend={{
        link: [
          { rel: 'alternate', hreflang: lang, href: canonical },
          { rel: 'alternate', hreflang: alternateLang, href: alternateUrl },
          { rel: 'alternate', hreflang: 'x-default', href: 'https://precisembc.com/en/' },
          {
            rel: 'preconnect',
            href: 'https://fonts.googleapis.com',
          },
          {
            rel: 'preconnect',
            href: 'https://fonts.gstatic.com',
            crossorigin: '',
          },
          {
            rel: 'stylesheet',
            href: 'https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Noto+Sans:wght@400;500;600;700&display=swap',
          },
        ],
        meta: [
          { name: 'robots', content: 'index, follow' },
          { name: 'theme-color', content: '#1d4ed8' },
        ],
      }}
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline define:vars={{ faviconLight, faviconDark, themeStorageKey }}>
      const themeMedia = window.matchMedia('(prefers-color-scheme: dark)');
      const root = document.documentElement;

      const getSystemTheme = () => themeMedia.matches ? 'dark' : 'light';

      const updateFavicon = (theme) => {
        const head = document.head;
        if (!head) return;

        let icon = document.querySelector('link[data-dynamic-favicon="true"]');
        if (!icon) {
          icon = document.createElement('link');
          icon.setAttribute('rel', 'icon');
          icon.setAttribute('type', 'image/png');
          icon.setAttribute('data-dynamic-favicon', 'true');
          head.appendChild(icon);
        }

        icon.setAttribute('href', theme === 'dark' ? faviconDark : faviconLight);
      };

      const updateThemeColor = (theme) => {
        const meta = document.querySelector('meta[name="theme-color"]');
        if (meta) {
          meta.setAttribute('content', theme === 'dark' ? '#020617' : '#1d4ed8');
        }
      };

      const applyThemePreference = (preference) => {
        const nextPreference = ['light', 'dark', 'system'].includes(preference) ? preference : 'system';
        const resolvedTheme = nextPreference === 'system' ? getSystemTheme() : nextPreference;

        root.dataset.themePreference = nextPreference;
        root.dataset.theme = resolvedTheme;
        root.style.colorScheme = resolvedTheme;

        localStorage.setItem(themeStorageKey, nextPreference);
        updateFavicon(resolvedTheme);
        updateThemeColor(resolvedTheme);

        window.dispatchEvent(new CustomEvent('themechange', {
          detail: { preference: nextPreference, theme: resolvedTheme },
        }));
      };

      window.__setThemePreference = applyThemePreference;
      window.__getThemePreference = () => root.dataset.themePreference || 'system';

      applyThemePreference(localStorage.getItem(themeStorageKey) || 'system');

      themeMedia.addEventListener('change', () => {
        if ((root.dataset.themePreference || 'system') === 'system') {
          applyThemePreference('system');
        }
      });
    </script>
  </head>

  <body class="antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-burgundy-500 focus:text-white focus:rounded-lg">
      Skip to main content
    </a>

    <slot />

    <script is:inline>
      // Header scroll effect
      const header = document.getElementById('site-header');
      if (header) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 20) {
            header.classList.add('scrolled');
          } else {
            header.classList.remove('scrolled');
          }
        }, { passive: true });
      }
    </script>
  </body>
</html>
